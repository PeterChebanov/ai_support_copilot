# =============================================================================
# Copy this file:  cp .env.example .env
# .env is gitignored — put your secrets and local settings here only.
# =============================================================================

# --- Required from EP02 (ingestion, embeddings) -----------------------------

# Your OpenAI API key (never commit this).
# Get it: https://platform.openai.com/api-keys → Create new secret key
# Example: sk-proj-xxxxxxxx...
OPENAI_API_KEY=sk-your-key-here

# --- Database ---------------------------------------------------------------

# Postgres from your host terminal (CLI: uv run python -m ingestion.cli ...).
# localhost:5433 maps to container port 5432 (see docker-compose.yml).
# User / password / database: copilot / copilot / copilot
DATABASE_URL=postgresql://copilot:copilot@localhost:5433/copilot

# The api container uses postgres:5432 — set in docker-compose.yml, not .env.

# --- Defaults (usually leave as-is) -----------------------------------------

REDIS_URL=redis://redis:6379/0
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVE_TOP_K=5
RETRIEVE_CANDIDATE_LIMIT=20
RRF_K=60
CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_ENTRIES=1000
